{
  "manifest_version": 3,
  "name": "WOLF GRADING ASSISTANT",
  "version": "1.0.0",
  "description": "Movable grading assistant panel for Canvas-like pages with rubric-aligned comments and quick copy actions.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "WOLF GRADING ASSISTANT"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
